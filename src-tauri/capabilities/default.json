{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Emit launcher permissions",
  "windows": ["main", "ruler-overlay"],
  "permissions": [
    "core:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "shell:allow-open",
    "updater:default",
    "process:allow-restart"
  ]
}
